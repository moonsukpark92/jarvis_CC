# Jarvis v5 — secret keys template
# Copy this file to `.env` and fill in real values.
# Never commit `.env`.

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: choose model (default in code). Examples:
#   claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Optional: OpenAI fallback (only if v4 archive is run) ---
OPENAI_API_KEY=

# --- Google tools (jarvis_v5/google_tools.py) ---
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# --- Telegram bot (jarvis_v5/telegram_bot.py) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Wake word / STT tuning (overrides defaults; leave blank to use code defaults) ---
STT_MODEL=base
STT_LANGUAGE=ko

# --- TTS ---
TTS_VOICE=ko-KR-InJoonNeural

# --- Logging ---
LOG_LEVEL=INFO
